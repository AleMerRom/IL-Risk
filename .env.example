# Ethereum JSON-RPC endpoint. Do not commit real keys.
RPC_URL=https://ethereum-rpc.publicnode.com

# Optional endpoint used specifically for eth_getLogs scans. Avoid Alchemy Free
# tier here because it caps eth_getLogs to very small block ranges.
LOG_RPC_URL=https://ethereum-rpc.publicnode.com
LOG_RPC_FALLBACK_URLS=https://rpc.ankr.com/eth,https://eth.llamarpc.com,https://1rpc.io/eth

# Optional separate archive endpoint. Required for historical eth_call Path A.
# Example: https://eth-mainnet.g.alchemy.com/v2/<your-key>
ARCHIVE_RPC_URL=

# Optional tuning.
RPC_MAX_LOGS_PER_REQUEST=10000
RPC_INITIAL_LOG_CHUNK_BLOCKS=1000
RPC_RATE_LIMIT_RPS=3
RPC_RATE_LIMIT_COOLDOWN=5
RPC_RATE_LIMIT_RETRIES=2
