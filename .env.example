# Ethereum JSON-RPC endpoint. Do not commit real keys.
RPC_URL=https://ethereum-rpc.publicnode.com

# Optional endpoint used specifically for eth_getLogs scans. Avoid Alchemy Free
# tier here because it caps eth_getLogs to very small block ranges.
LOG_RPC_URL=https://ethereum-rpc.publicnode.com
LOG_RPC_FALLBACK_URLS=https://rpc.ankr.com/eth,https://eth.llamarpc.com,https://1rpc.io/eth

# Optional separate archive endpoint. Required for historical eth_call Path A.
# Example: https://eth-mainnet.g.alchemy.com/v2/<your-key>
ARCHIVE_RPC_URL=

# Optional tuning.
RPC_MAX_LOGS_PER_REQUEST=10000
RPC_INITIAL_LOG_CHUNK_BLOCKS=1000
RPC_RATE_LIMIT_RPS=3
RPC_RATE_LIMIT_COOLDOWN=5
RPC_RATE_LIMIT_RETRIES=2

# Optional, but recommended for Module 5 Task 5.2 full-window Hyperliquid
# hourly OHLCV. Hyperliquid's public candle endpoint only exposes the most
# recent 5000 candles, so the 2025-10-01 -> 2026-03-31 study window usually
# needs an indexed historical provider. Leave blank to use the official public
# Hyperliquid /info API where it has enough coverage.
QUICKNODE_SQL_API_KEY="QN_b75af03c5fbb4d46823c6e6966b312b3"

# Alternative Module 5 historical provider. 0xArchive exposes Hyperliquid
# hourly candles plus historical mark/oracle price data through REST.
ZEROXARCHIVE_API_KEY=
# Backward-compatible alias also accepted by the collector:
# ZEROARCHIVE_API_KEY=
# 0xArchive CLI/MCP aliases also accepted by the collector:
# OXARCHIVE_API_KEY=
# OXA_API_KEY=

# Paid/indexed archive provider with historical native Hyperliquid oracle data.
ALLIUM_API_KEY=
