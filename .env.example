# Ethereum JSON-RPC endpoint. Do not commit real keys.
RPC_URL=

# Optional endpoint used specifically for eth_getLogs scans. This should not be
# an Alchemy Free tier URL, because that tier caps eth_getLogs to 10 blocks.
LOG_RPC_URL=
LOG_RPC_FALLBACK_URLS=

# Optional separate archive endpoint. Required for historical eth_call path A.
ARCHIVE_RPC_URL=

# Optional tuning.
RPC_MAX_LOGS_PER_REQUEST=
RPC_INITIAL_LOG_CHUNK_BLOCKS=500
RPC_RATE_LIMIT_RPS=3
RPC_RATE_LIMIT_COOLDOWN=5
RPC_RATE_LIMIT_RETRIES=3
